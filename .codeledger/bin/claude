#!/usr/bin/env bash
# Ambient CodeLedger wrapper for claude — auto-generated by codeledger vendor
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
run_auto_refresh() {
  local prompt="$1"
  if [ -z "$prompt" ]; then
    return 0
  fi
  "$SCRIPT_DIR/codeledger" auto-refresh --quiet --prompt "$prompt" >/dev/null 2>&1 || true
  mkdir -p "$REPO_ROOT/.codeledger/runtime"
  "$SCRIPT_DIR/codeledger" broker refresh --task "$prompt" --json > "$REPO_ROOT/.codeledger/runtime/latest-broker-refresh.json" 2>/dev/null || true
  "$SCRIPT_DIR/codeledger" broker current --json > "$REPO_ROOT/.codeledger/runtime/latest-broker-current.json" 2>/dev/null || true
  "$SCRIPT_DIR/codeledger" broker timeline --limit 10 --json > "$REPO_ROOT/.codeledger/runtime/latest-broker-timeline.json" 2>/dev/null || true
  printf '%s\n' '{"schema_version":"codeledger/broker-first/v1","policy":"broker_first","refresh_artifact":".codeledger/runtime/latest-broker-refresh.json","current_artifact":".codeledger/runtime/latest-broker-current.json","timeline_artifact":".codeledger/runtime/latest-broker-timeline.json","raw_search":"fallback_after_broker_insufficient"}' > "$REPO_ROOT/.codeledger/runtime/latest-broker-contract.json" 2>/dev/null || true
}
if [ $# -eq 0 ]; then
  exec "$SCRIPT_DIR/codeledger" claude
fi
if [ "$1" = "--task" ]; then
  run_auto_refresh "${2:-}"
  exec "$SCRIPT_DIR/codeledger" claude "$@"
fi
PROMPT="$1"
shift
run_auto_refresh "$PROMPT"
exec "$SCRIPT_DIR/codeledger" claude --task "$PROMPT" "$@"
